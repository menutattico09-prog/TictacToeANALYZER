{
  "entities": {
    "Match": {
      "title": "Match",
      "description": "A saved Ultimate Tic-Tac-Toe match",
      "type": "object",
      "properties": {
        "board": {
          "type": "array",
          "description": "The 81 cells of the board"
        },
        "subGridWinners": {
          "type": "array",
          "description": "The winners of the 9 subgrids"
        },
        "nextPlayer": {
          "type": "string",
          "enum": ["X", "O"]
        },
        "activeSubGrid": {
          "type": "number",
          "description": "The index of the active subgrid (0-8 or null)"
        },
        "winner": {
          "type": "string",
          "description": "The winner of the match (X, O, or null)"
        },
        "isGameOver": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who saved the match"
        },
        "matchName": {
          "type": "string",
          "description": "A custom name for the match"
        }
      },
      "required": ["board", "subGridWinners", "nextPlayer", "isGameOver", "timestamp", "userId"]
    },
    "Room": {
      "title": "Room",
      "description": "A multiplayer game room",
      "type": "object",
      "properties": {
        "board": { "type": "array" },
        "subGridWinners": { "type": "array" },
        "nextPlayer": { "type": "string", "enum": ["X", "O"] },
        "activeSubGrid": { "type": "number" },
        "winner": { "type": "string" },
        "isGameOver": { "type": "boolean" },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "players": {
          "type": "object",
          "properties": {
            "p1": { "type": "string" },
            "p2": { "type": "string" }
          }
        },
        "p1Symbol": { "type": "string", "enum": ["X", "O"] },
        "p2Symbol": { "type": "string", "enum": ["X", "O"] },
        "options": {
          "type": "object",
          "properties": {
            "showAnalysis": { "type": "boolean" },
            "startingPlayer": { "type": "string", "enum": ["p1", "p2", "random"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMoveAt": { "type": "string", "format": "date-time" }
      },
      "required": ["board", "subGridWinners", "nextPlayer", "isGameOver", "status", "players", "createdAt"]
    }
  },
  "firestore": {
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of saved matches"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of multiplayer rooms"
    }
  }
}
