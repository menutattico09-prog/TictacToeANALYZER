rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: matches
    // Document ID: auto-generated
    // Fields:
    //   - board: list (required) - 81 cells
    //   - subGridWinners: list (required) - 9 subgrid states
    //   - nextPlayer: string (required, X or O)
    //   - activeSubGrid: number (optional)
    //   - winner: string (optional)
    //   - isGameOver: bool (required)
    //   - timestamp: timestamp (required)
    //   - userId: string (required) - Owner UID
    //   - matchName: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMatch(data) {
      return data.board is list && data.board.size() == 81 &&
             data.subGridWinners is list && data.subGridWinners.size() == 9 &&
             data.nextPlayer in ['X', 'O'] &&
             data.isGameOver is bool &&
             data.timestamp is timestamp &&
             data.userId is string && data.userId.size() > 0 &&
             (!('matchName' in data) || (data.matchName is string && data.matchName.size() <= 100));
    }

    function isValidRoom(data) {
      return data.board is list && data.board.size() == 81 &&
             data.subGridWinners is list && data.subGridWinners.size() == 9 &&
             data.nextPlayer in ['X', 'O'] &&
             data.isGameOver is bool &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.players is map &&
             data.players.p1 is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /matches/{matchId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && isValidMatch(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      isOwner(request.resource.data.userId) && 
                      isValidMatch(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.players.p1 == request.auth.uid &&
                      isValidRoom(request.resource.data);
      allow update: if isAuthenticated() && (
        // Joining as P2
        (resource.data.status == 'waiting' && 
         request.resource.data.players.p2 == request.auth.uid) ||
        // Making a move
        (request.auth.uid == resource.data.players.p1 || request.auth.uid == resource.data.players.p2)
      ) && isValidRoom(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.players.p1 == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
